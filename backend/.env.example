# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://zxzvpofnvwpvdwaakvrt.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_KEY=sb_secret_...

# ── LLM — Groq (router, classifier, wiki maintainer) ─────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_...

# ── Embeddings ────────────────────────────────────────────────────────────────
# "local" = sentence-transformers (no API key; slower on first run while model downloads)
# "together" = Together AI hosted nomic-embed-text (needs TOGETHER_API_KEY below)
EMBEDDING_PROVIDER=local

# Required only if EMBEDDING_PROVIDER=together
# Get a key at https://api.together.ai
TOGETHER_API_KEY=

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_POLL_INTERVAL_SECONDS=10
MAX_JOB_RETRIES=3

# ── CORS — comma-separated list of allowed frontend origins ───────────────────
CORS_ORIGINS=http://localhost:3000

# ── Database direct connection (required only for apply_migrations.py) ────────
# Get the password from Supabase Dashboard → Project Settings → Database
SUPABASE_DB_URL=postgresql://postgres.zxzvpofnvwpvdwaakvrt:YOUR_DB_PASSWORD@aws-0-eu-west-2.pooler.supabase.com:5432/postgres
